rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read any user doc (for leaderboard display names),
    // but only write their own
    match /users/{uid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null && request.auth.uid == uid;
      allow delete: if false;
    }

    // Leaderboard: anyone logged in can read; only owner writes their entry
    match /leaderboard/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // PvP matches: any authenticated user can participate
    match /pvp_matches/{matchId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.players.hasAny([request.auth.uid]);
      allow update: if request.auth != null
        && (resource.data.players.hasAny([request.auth.uid])
            || resource.data.status == 'waiting');
      allow delete: if request.auth != null
        && resource.data.players.hasAny([request.auth.uid]);
    }
  }
}
